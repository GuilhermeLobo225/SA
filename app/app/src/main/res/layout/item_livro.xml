<?xml version="1.0" encoding="utf-8"?>
<!-- Linha de um livro no catálogo. -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/bg_surface"
    android:paddingHorizontal="16dp"
    android:paddingVertical="12dp">

    <!-- Título -->
    <TextView
        android:id="@+id/titulo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textColor="@color/text_strong"
        android:textStyle="bold"
        android:textSize="14sp"
        android:maxLines="2"
        android:ellipsize="end"
        tools:text="Artificial Intelligence: A Modern Approach"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/pill"
        app:layout_constraintHorizontal_bias="0" />

    <!-- Autor -->
    <TextView
        android:id="@+id/autor"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:textColor="@color/text_body"
        android:textSize="12.5sp"
        android:textStyle="italic"
        tools:text="Stuart Russell e Peter Norvig"
        app:layout_constraintTop_toBottomOf="@id/titulo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/pill" />

    <!-- Meta: área · ano · cota · biblioteca -->
    <TextView
        android:id="@+id/meta"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textColor="@color/text_muted"
        android:textSize="11sp"
        android:fontFamily="monospace"
        tools:text="Computação · 2020 · CS/RUS/01 · BGUM"
        app:layout_constraintTop_toBottomOf="@id/autor"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/pill" />

    <!-- Pill de disponibilidade -->
    <TextView
        android:id="@+id/pill"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/pill_ok"
        android:paddingHorizontal="10dp"
        android:paddingVertical="4dp"
        android:textSize="11sp"
        android:textStyle="bold"
        android:textColor="@color/status_free"
        tools:text="6 de 6"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <View
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_marginTop="12dp"
        android:background="@color/border_soft"
        app:layout_constraintTop_toBottomOf="@id/meta"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>

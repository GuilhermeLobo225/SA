<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_page">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/uminho_red">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="@string/title_historico"
            app:titleTextColor="@color/text_on_red"
            app:subtitleTextColor="@color/uminho_red_soft"
            app:navigationIcon="?attr/homeAsUpIndicator" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingVertical="20dp">

            <!-- Cabeçalho -->
            <TextView
                style="@style/TextAppearance.SA.Eyebrow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/historico_eyebrow" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/historico_titulo"
                android:textColor="@color/text_strong"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/historico_descricao"
                android:textColor="@color/text_muted"
                android:textSize="13sp" />

            <!-- Chips de seleção de métrica -->
            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chips_target"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                app:singleSelection="true"
                app:selectionRequired="true"
                app:chipSpacingHorizontal="6dp"
                app:chipSpacingVertical="6dp" />

            <!-- Cartão do gráfico -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/card_background"
                android:padding="16dp">

                <pt.uminho.sa.ui.HistoryChartView
                    android:id="@+id/chart"
                    android:layout_width="match_parent"
                    android:layout_height="260dp" />

                <ProgressBar
                    android:id="@+id/loading"
                    style="?android:attr/progressBarStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:indeterminateTint="@color/uminho_red"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/empty_state"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="@string/historico_vazio"
                    android:textColor="@color/text_muted"
                    android:textSize="12sp"
                    android:visibility="gone" />
            </FrameLayout>

            <!-- Legenda manual: indica que a linha cheia é histórico e a tracejada previsão -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal"
                android:gravity="center">

                <View
                    android:layout_width="14dp"
                    android:layout_height="2dp"
                    android:background="@color/uminho_red" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="@string/legenda_historico"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp" />

                <View
                    android:layout_width="14dp"
                    android:layout_height="2dp"
                    android:layout_marginStart="16dp"
                    android:background="@color/uminho_blue" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="@string/legenda_previsao"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- Metadata por baixo do gráfico -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/card_background"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:id="@+id/meta_modelo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_body"
                    android:textSize="13sp"
                    tools:text="Modelo: Holt-Winters (sazonal)" />

                <TextView
                    android:id="@+id/meta_unidade"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/text_muted"
                    android:textSize="12sp"
                    tools:text="Unidade: °C" />

                <TextView
                    android:id="@+id/meta_fonte"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textAllCaps="true"
                    android:letterSpacing="0.08"
                    tools:text="● Em direto · API local" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>

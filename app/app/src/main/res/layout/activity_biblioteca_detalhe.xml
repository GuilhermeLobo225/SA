<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_page">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/uminho_red">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:titleTextColor="@color/text_on_red"
            app:subtitleTextColor="@color/uminho_red_soft"
            app:navigationIcon="?attr/homeAsUpIndicator" />
    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingVertical="20dp">

            <!-- ===== Cabeçalho da página ===== -->
            <TextView
                android:id="@+id/eyebrow"
                style="@style/TextAppearance.SA.Eyebrow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:text="BGUM · Campus Gualtar" />

            <TextView
                android:id="@+id/titulo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/text_strong"
                android:textSize="24sp"
                android:textStyle="bold"
                tools:text="Biblioteca Geral da UMinho" />

            <TextView
                android:id="@+id/descricao"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/text_muted"
                android:textSize="14sp"
                tools:text="Biblioteca principal do campus de Gualtar." />

            <!-- ===== Banner "sem sensorização" (mostrado para bibliotecas sem nó) ===== -->
            <LinearLayout
                android:id="@+id/no_sensor_banner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:background="@drawable/banner_dashed"
                android:orientation="vertical"
                android:padding="20dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/sem_sensorizacao_titulo"
                    android:textColor="@color/text_strong"
                    android:textStyle="bold"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/sem_sensorizacao_msg"
                    android:textColor="@color/text_muted"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- ===== Bloco completo de sensorização (só aparece para a BG) ===== -->
            <LinearLayout
                android:id="@+id/sensor_block"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- Cartão Ocupação -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:background="@drawable/card_background"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_users"
                            android:contentDescription="@string/ocupacao_titulo" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:text="@string/ocupacao_titulo"
                            android:textColor="@color/text_strong"
                            android:textStyle="bold"
                            android:textSize="15sp" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="10dp"
                        android:background="@color/border_soft" />

                    <!-- Linha: percentagem grande + texto -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/percentagem"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/uminho_red"
                            android:textStyle="bold"
                            android:textSize="40sp"
                            tools:text="58%" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="16dp"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/fonte_dados"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textAllCaps="true"
                                android:letterSpacing="0.08"
                                android:textSize="11sp"
                                android:textColor="@color/text_muted"
                                android:textStyle="bold"
                                tools:text="● Em direto · API local" />

                            <TextView
                                android:id="@+id/estado"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:textColor="@color/text_strong"
                                android:textStyle="bold"
                                android:textSize="18sp"
                                tools:text="Parcialmente ocupado" />

                            <TextView
                                android:id="@+id/lugares_txt"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:fontFamily="monospace"
                                android:textColor="@color/text_muted"
                                android:textSize="12sp"
                                tools:text="7 de 12 lugares ocupados" />
                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/ultima_leitura"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:gravity="end"
                        android:fontFamily="monospace"
                        android:textSize="11sp"
                        android:textColor="@color/text_muted"
                        tools:text="Última leitura: 14:32:11" />
                </LinearLayout>

                <!-- Cartão Planta -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/card_background"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_chair"
                            android:contentDescription="@string/planta_titulo" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:text="@string/planta_titulo"
                            android:textColor="@color/text_strong"
                            android:textStyle="bold"
                            android:textSize="15sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/planta_descricao"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textColor="@color/text_muted"
                        android:textSize="12sp"
                        tools:text="Sala de Leitura - Piso 1. A zona A está abrangida pelo campo de visão." />

                    <!-- Custom View que desenha a planta -->
                    <pt.uminho.sa.ui.PlantaView
                        android:id="@+id/planta"
                        android:layout_width="match_parent"
                        android:layout_height="220dp"
                        android:layout_marginTop="12dp" />
                </LinearLayout>

                <!-- Cartão Sensores -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/card_background"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_thermometer"
                            android:contentDescription="@string/sensores_titulo" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:text="@string/sensores_titulo"
                            android:textColor="@color/text_strong"
                            android:textStyle="bold"
                            android:textSize="15sp" />
                    </LinearLayout>

                    <!-- GridLayout: 2 colunas de mosaicos preenchidos por código -->
                    <GridLayout
                        android:id="@+id/grid_sensores"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:columnCount="2"
                        android:useDefaultMargins="true" />
                </LinearLayout>

                <!-- ===== Painel resumo de previsão (próxima hora) ===== -->
                <LinearLayout
                    android:id="@+id/previsao_block"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/card_background"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_info"
                            android:contentDescription="@string/previsao_titulo" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:text="@string/previsao_titulo"
                            android:textColor="@color/text_strong"
                            android:textStyle="bold"
                            android:textSize="15sp" />

                        <TextView
                            android:id="@+id/prev_fonte"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_muted"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:textAllCaps="true"
                            android:letterSpacing="0.08"
                            tools:text="API LOCAL" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/previsao_descricao"
                        android:textColor="@color/text_muted"
                        android:textSize="12sp" />

                    <!-- 3 colunas: temperatura / ruído / qualidade do ar -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:orientation="horizontal">

                        <!-- Temperatura -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/sensor_temperatura"
                                android:textColor="@color/text_muted"
                                android:textSize="11sp"
                                android:textAllCaps="true"
                                android:letterSpacing="0.06" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <TextView
                                    android:id="@+id/prev_temp_valor"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="monospace"
                                    android:textColor="@color/text_strong"
                                    android:textSize="18sp"
                                    android:textStyle="bold"
                                    tools:text="22.4 °C" />

                                <TextView
                                    android:id="@+id/prev_temp_seta"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="4dp"
                                    android:textSize="18sp"
                                    android:textStyle="bold"
                                    tools:text="↗" />
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Ruído -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/sensor_ruido"
                                android:textColor="@color/text_muted"
                                android:textSize="11sp"
                                android:textAllCaps="true"
                                android:letterSpacing="0.06" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <TextView
                                    android:id="@+id/prev_ruido_valor"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="monospace"
                                    android:textColor="@color/text_strong"
                                    android:textSize="18sp"
                                    android:textStyle="bold"
                                    tools:text="38 dB" />

                                <TextView
                                    android:id="@+id/prev_ruido_seta"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="4dp"
                                    android:textSize="18sp"
                                    android:textStyle="bold"
                                    tools:text="→" />
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Qualidade do ar -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/sensor_qualidade_ar"
                                android:textColor="@color/text_muted"
                                android:textSize="11sp"
                                android:textAllCaps="true"
                                android:letterSpacing="0.06" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <TextView
                                    android:id="@+id/prev_ar_valor"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="monospace"
                                    android:textColor="@color/text_strong"
                                    android:textSize="18sp"
                                    android:textStyle="bold"
                                    tools:text="320" />

                                <TextView
                                    android:id="@+id/prev_ar_seta"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="4dp"
                                    android:textSize="18sp"
                                    android:textStyle="bold"
                                    tools:text="↘" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- ===== Botão para abrir o ecrã de histórico completo ===== -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_abrir_historico"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/abrir_historico"
                    android:visibility="gone" />

                <!-- Botões de Geofencing -->
                <LinearLayout
                    android:id="@+id/geofence_actions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal"
                    android:visibility="gone">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_registar_geofence"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/geofence_registar" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_remover_geofence"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:text="@string/geofence_remover" />
                </LinearLayout>
            </LinearLayout>

            <!-- ===== Painel de informações (sempre visível) ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/card_background"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_info"
                        android:contentDescription="@string/info_titulo" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:text="@string/info_titulo"
                        android:textColor="@color/text_strong"
                        android:textStyle="bold"
                        android:textSize="15sp" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="14dp"
                    android:background="@color/border_soft" />

                <!-- A app preenche estas TextViews em runtime -->
                <TextView android:id="@+id/info_sigla"    style="@style/TextAppearance.Material3.BodyMedium" android:layout_width="match_parent" android:layout_height="wrap_content" />
                <TextView android:id="@+id/info_campus"   style="@style/TextAppearance.Material3.BodyMedium" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" />
                <TextView android:id="@+id/info_morada"   style="@style/TextAppearance.Material3.BodyMedium" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" />
                <TextView android:id="@+id/info_telefone" style="@style/TextAppearance.Material3.BodyMedium" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" />
                <TextView android:id="@+id/info_email"    style="@style/TextAppearance.Material3.BodyMedium" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:autoLink="email" />
                <TextView android:id="@+id/info_lugares"  style="@style/TextAppearance.Material3.BodyMedium" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" />
                <TextView android:id="@+id/info_horario_letivo" style="@style/TextAppearance.Material3.BodyMedium" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" />
                <TextView android:id="@+id/info_horario_ferias" style="@style/TextAppearance.Material3.BodyMedium" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
